{
  "manifest_version": 3,
  "name": "Linear View Diff",
  "description": "Adds a View Diff button to Linear PR review pages and renders GitHub PR file trees and diffs in-page.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://linear.app/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://linear.app/*/review/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html"
}
